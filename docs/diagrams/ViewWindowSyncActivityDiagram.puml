@startuml
title View Window Auto-Sync Logic

start

if (ViewWindow is visible?) then ([yes])
    :Get person currently displayed in ViewWindow;
    :Check if this person still exists
    in the main (filtered) person list;

    if (Person still in list?) then ([yes])
        :Get updated person object;
        :Refresh ViewWindow with updated details;
        :Re-select person in list and scroll to them;
    else ([no])
        :Clear ViewWindow content;
        :Remove ViewWindow from display;
        :Clear selection from person list;
    endif
else ([no])
    ' Do nothing
endif

stop

@enduml

