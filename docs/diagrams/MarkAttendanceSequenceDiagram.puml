@startuml
!include style.puml
skinparam ArrowFontStyle plain

box Logic LOGIC_COLOR_T1
participant "MarkAttendanceCommand" as Command LOGIC_COLOR
end box

box Model MODEL_COLOR_T1
participant "WeekList" MODEL_COLOR
participant "Week" MODEL_COLOR
end box

Command -> WeekList : markWeekAsAttended(index)
activate Command

WeekList -> WeekList : validate index
activate WeekList

WeekList -> Week : markAsAttended()
activate Week

alt Already marked as Y
    Week --> WeekList : throw IllegalStateException
    WeekList --> Command : propagate exception
else Valid update
    Week -> Week : update status = Y
    Week --> WeekList : success
end

WeekList --> Command : return

deactivate Week
deactivate WeekList
deactivate Command

@enduml
